# Copy to .env for local dev (node server.js). In production these are set in the
# Netlify dashboard under Site settings → Environment variables — NOT committed.

# Free vision provider for AI screenshot import (set either or both).
# Gemini: https://aistudio.google.com/apikey   (free, no credit card)
GEMINI_API_KEY=

# Groq fallback: https://console.groq.com/keys   (free)
GROQ_API_KEY=

# Optional model overrides
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
