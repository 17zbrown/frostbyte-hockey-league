# Dependencies
node_modules/

# Secrets — never commit API keys
.env
.env.*
!.env.example

# Netlify local state
.netlify/

# Editor / OS
.DS_Store
.claude/

# Local reference material (not needed for the site)
*.pdf

# Logs
*.log
npm-debug.log*

# Build output — generated from src/live/ by build.cjs.
# index.html is built by Netlify at deploy time (see netlify.toml); the staging/
# prototype builds aren't shipped. Keeps git history from carrying ~700KB blobs.
index.html
chelgaming-live.html
chelgaming-preview.html
redesign-preview.html
